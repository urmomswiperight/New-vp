          }
        ]
      ]
    },
    "Get Active Campaigns": {
      "main": [
        [
          {
            "node": "Get 50 New Leads",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get 50 New Leads": {
      "main": [
        [
          {
            "node": "Research Lead/Company",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Research Lead/Company": {
      "main": [
        [
          {
            "node": "Agentic Reasoning & Draft",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Agentic Reasoning & Draft": {
      "main": [
        [
          {
            "node": "Save Draft (HITL)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Save Draft (HITL)": {
