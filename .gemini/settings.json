        "--header",
        "authorization:Bearer 2UMkvorrEC9jgw0b096dd6468f702e66b2e81de339e48bdbf"
      ]
    },
    "linkedin": {
      "command": "npx",
      "args": [
        "ts-node",
        "--esm",
        "scripts/linkedin-mcp-server.ts"
      ]
    },
    "gumroad": {
      "command": "npx",
      "args": [
        "-y",
        "gumroad-mcp@latest"
