            "index": 0
          }
        ]
      ]
    },
    "Split in Batches": {
      "main": [
        [
          {
            "node": "Safety Wait (2m)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Safety Wait (2m)": {
      "main": [
        [
          {
            "node": "ManyReach Send",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "ManyReach Send": {
      "main": [
        [
          {
            "node": "Check for Error",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Check for Error": {
      "main": [
        [
          {
            "node": "Mark Error",
            "type": "main",
