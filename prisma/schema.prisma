// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                        String         @id @default(uuid())
  email                     String?        @unique
  lemon_squeezy_customer_id String?        @unique
  usage_count               Int            @default(0)
  createdAt                 DateTime       @default(now())
  leads                     Lead[]
  campaigns                 Campaign[]
  subscriptions             Subscription[]
  senderAccounts            SenderAccount[]
}

model SenderAccount {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email         String   @unique
  smtpHost      String
  smtpPort      Int
  smtpPassword  String
  imapHost      String
  imapPort      Int
  imapPassword  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model Lead {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  firstName String?
  lastName  String?
  company   String?
  linkedinUrl String?
  status    String   @default("New")
  sentiment String?  // e.g., POSITIVE, NEGATIVE, NEUTRAL
  lastMessage String?
  followUpStep Int     @default(0)
  region    String?
  variant   String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  drafts    LeadDraft[]

  @@index([userId])
}

model LeadDraft {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  campaignId String
  campaign  Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  content   String
  subject   String?
  status    String   @default("Pending") // Pending, Approved, Rejected, Sent
  reasoning Json?      // AI reasoning for the draft
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([campaignId])
}

model Campaign {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  type      String   @default("Email") // e.g., Email, LinkedIn
  status    String   @default("Paused") // e.g., Paused, Active, Completed
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  drafts    LeadDraft[]

  @@index([userId])
}

enum SubscriptionStatus {
  active
  trialing
  past_due
  canceled
  unpaid
  pending_verification
  inactive
}

model Subscription {
  id                        String             @id @default(uuid())
  userId                    String             @unique
  user                      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  lemon_squeezy_id          String?            @unique
  fiverr_order_id           String?            @unique
  gumroad_sale_id           String?            @unique
  gumroad_license_key       String?
  variant_id                String?
  status                    SubscriptionStatus @default(inactive)
  current_period_end        DateTime?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
}

