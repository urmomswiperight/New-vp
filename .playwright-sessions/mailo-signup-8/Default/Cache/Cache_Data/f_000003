			div.style.display="block";
			div.style.position="absolute";

			div.style.left=(pos[0]+wr*width)+"px";
			div.style.width=width+"px";

			div.style.top=top+"px";
			var height=ea_elt_height(div);
			top+=height;
			div.style.visibility="visible";
		}
	}
