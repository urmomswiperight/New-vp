		for (var i=0;i<elts.length;i++) {
			var elt=elts[i];
			if ((elt.type!="checkbox")||(elt.name!=cname))
				continue;
			if (elt.checked) {
				if (elt.value==cvalue)
					right_drag=true;
				this.checked=true;
				for (var j=0;j<tab.length;j++) {
					var c={type:tab[j],value:decodeURIComponent(elt.value)};
					this.content.push(c);
				}
			}
