				nb++;
		}
		if (nb>1)
			ea_list_preview_uncheck();
		ea_list_manage_buttons(form,name);
		return false;
	}
	ea_list_checked=0;
	var already=0;
	var found=0;
	var next=new Array();
	var elts=ea_gettags("input");
	var del_other=((down==1)&&!e.ctrlKey&&!e.shiftKey&&(form.getAttribute("ea_selectmode")!=1));
	var nb=0;
