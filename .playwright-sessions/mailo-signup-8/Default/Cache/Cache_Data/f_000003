			var x=ea_mouse_obj.e.clientX;
			var y=ea_mouse_obj.e.clientY;
		}

		x-=ea_mouse_obj.offset[0];
		if (x<ea_mouse_obj.min[0])
			x=ea_mouse_obj.min[0];
		else if (x>ea_mouse_obj.max[0])
			x=ea_mouse_obj.max[0];
