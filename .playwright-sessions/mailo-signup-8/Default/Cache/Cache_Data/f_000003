	} else
		this.content=ctype;
	if (!right_drag) {
		this.checked=false;
		while (this.content.length>0)
			this.content.pop();
	}
	if (opt)
		this.opt=opt;
	else
		this.opt="";
	this.pos0X=e.clientX;
	this.pos0Y=e.clientY;
	/* this.offsetY=ea_scrolltop(); */
	this.offsetY=0;
	var obj=ea_getid("mouse_MOVE_TEXT");
