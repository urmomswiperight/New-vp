		nbIter = 10;

	try {
		if (func())
			return;
	} catch (e) {
		console.log(e);
	}

	var idx = 1; 
	var loopIn = function() {
		if (idx++ < nbIter)
			try {
				if (!func())
					return;
			} catch (e) {
