			if (found==0) {
				if (already==1)
					ea_list_selectline(elt,true);
				else if (elt.checked)
					already=1;
				continue;
			}
			if (elt.checked) {
				for(var j=0;j<next.length;j++)
					ea_list_selectline(next[j],true);
				next=new Array();
			} else
				next.push(elt);
