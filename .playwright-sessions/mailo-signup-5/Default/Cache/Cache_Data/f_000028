				elt.title="Compulsory field";
				ea_display_id("id_users_create",false);
				break;
			default:
				break;
			}
		}
	} else {
		switch (info) {
		case "2":
			elt.title="The security of this password is correct";
			ea_elt_addclass(elt,"cl_dot_ok");
			break;
		case "3":
			elt.title="The security of this password is correct";
			ea_elt_addclass(elt,"cl_dot_ok");
			break;
		default:
			ea_elt_addclass(elt,"cl_dot_ok");
			break;
		}
	}
