function ea_share_display_method(val)
{
	var lvl=parseInt(val,10);
	for(var i=0;i<=5;i++) {
		if ((i==1)||(i==4))
			continue;
		ea_display_id("id_help"+i,(i==lvl));
		ea_display_id("id_main"+i,(i==lvl));
		var new_id="id_extra"+i+"_";
		var j=1;
		while (1) {
			var id=new_id+j;
			if (document.getElementById(id)==null)
				break;
			ea_display_id(id,(i==lvl));
			j++;
			if (j>100)
				break;
		}
	}
}
