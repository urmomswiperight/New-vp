	}

	if (val=='premium-250G') {
		var total=period*5;
		var t=ea_decimal(total.toFixed(2));
		obj_total.innerHTML="€"+t+"";
	}

	if (val=='premium-500G') {
		var total=period*10;
		var t=ea_decimal(total.toFixed(2));
		obj_total.innerHTML="€"+t+"";
	}

	return ea_auth_pack_value_total();
