{
  "name": "MASTER: LinkedIn Conversational AI (V7 - Webhook Triggered)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "triggerAtHour": 9
            }
          ]
        }
      },
      "id": "trigger-9am-outreach",
      "name": "9AM: Start Outreach",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        -200,
        100
      ]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "linkedin-inbound",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Webhook: LinkedIn Inbound",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        -200,
        500
      ],
      "webhookId": "linkedin-inbound"
    },
    {
      "parameters": {
        "model": "gpt-4o",
        "prompt": "={{ \"You are Robel's AI Assistant. A lead named \" + $json.body.firstName + \" just replied to our LinkedIn outreach. \\n\\nLead Message: '\" + $json.body.lastMessage + \"'\\n\\nYour Goal: Have a human-like conversation. Do NOT send a booking link yet unless they explicitly ask for a call or how it works. \\n\\nRules:\\n1. Be brief (max 40 words).\\n2. Ask one insightful question about their current lead gen or how they find clients now.\\n3. Use a helpful, non-salesy tone. \\n4. Context: We build AI outreach systems that process 5,000 leads/mo for $0/mo SaaS cost.\" }}",
        "options": {
          "temperature": 0.7
        }
      },
      "id": "ai-chat-agent",
      "name": "AI: Conversational Agent",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [
        100,
        500
      ],
      "credentials": {
        "openAiApi": {
          "id": "OpenAI-Credential-ID",
          "name": "OpenAI"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://your-vercel-url.com/api/linkedin/reply",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Outreach-Secret",
              "value": "YOUR_SECRET_PASSWORD"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ \n  JSON.stringify({\n    threadUrl: $node[\"Webhook: LinkedIn Inbound\"].json.body.threadUrl,\n    message: $node[\"AI: Conversational Agent\"].json.choices[0].message.content\n  })\n}}",
        "options": {}
      },
      "id": "api-send-chat",
      "name": "Vercel API: Send Chat",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        400,
        500
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "assign-no-link",
              "name": "personalizedMessage",
              "value": "={{ $json.metadata?.draft || (\"Hi \" + $json.firstName + \", I saw your work at \" + $json.company + \". We help founders scale outreach using AI—would love to connect!\") }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "edit-message",
      "name": "Construct Icebreaker (No Link)",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        500,
        100
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://your-vercel-url.com/api/linkedin/outreach",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Outreach-Secret",
              "value": "YOUR_SECRET_PASSWORD"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ \n  JSON.stringify({\n    profileUrl: $('Split In Batches').item.json.linkedinUrl,\n    message: $json.personalizedMessage\n  })\n}}",
        "options": {}
      },
      "id": "api-outreach",
      "name": "Vercel API: Send Connection",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        750,
        100
      ]
    },
    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "id": "split-in-batches",
      "name": "Split In Batches",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 1,
      "position": [
        300,
        100
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "tableName": "Lead",
        "limit": 25,
        "filters": {
          "conditions": [
            {
              "key": "status",
              "value": "Drafted"
            }
          ]
        }
      },
      "id": "supabase-fetch-leads",
      "name": "Supabase: Fetch 25 Leads",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        50,
        100
      ],
      "credentials": {
        "supabaseApi": {
          "id": "Supabase-Credential-ID",
          "name": "Supabase"
        }
      }
    },
    {
      "parameters": {
        "amount": 45,
        "unit": "seconds"
      },
      "id": "wait-node",
      "name": "Wait 45s",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [
        1000,
        100
      ]
    }
  ],
  "connections": {
    "9AM: Start Outreach": {
      "main": [
        [
          {
            "node": "Supabase: Fetch 25 Leads",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Webhook: LinkedIn Inbound": {
      "main": [
        [
          {
            "node": "AI: Conversational Agent",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "AI: Conversational Agent": {
      "main": [
        [
          {
            "node": "Vercel API: Send Chat",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Supabase: Fetch 25 Leads": {
      "main": [
        [
          {
            "node": "split-in-batches",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "split-in-batches": {
      "main": [
        [
          {
            "node": "edit-message",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "edit-message": {
      "main": [
        [
          {
            "node": "api-outreach",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "api-outreach": {
      "main": [
        [
          {
            "node": "wait-node",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "wait-node": {
      "main": [
        [
          {
            "node": "split-in-batches",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
